# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_management
DB_USER=postgres
DB_PASSWORD=changeme
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
